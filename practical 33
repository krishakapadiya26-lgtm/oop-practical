import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.layout.VBox;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import javafx.scene.text.FontPosture;
import javafx.scene.text.FontWeight;
import javafx.scene.text.Text;
import javafx.stage.Stage;

import java.util.Random;

public class TextVBoxDemo extends Application {

    @Override
    public void start(Stage stage) {
        VBox vbox = new VBox(15);
        vbox.setStyle("-fx-alignment: center;");

        Random random = new Random();
        Font font = Font.font("Times New Roman", FontWeight.BOLD, FontPosture.ITALIC, 22);

        for (int i = 1; i <= 5; i++) {
            Text text = new Text("Text " + i);
            text.setFont(font);

            double opacity = 0.3 + (1.0 - 0.3) * random.nextDouble();
            Color color = Color.color(random.nextDouble(), random.nextDouble(), random.nextDouble(), opacity);
            text.setFill(color);

            vbox.getChildren().add(text);
        }

        Scene scene = new Scene(vbox, 400, 300);
        stage.setTitle("JavaFX Text VBox");
        stage.setScene(scene);
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
